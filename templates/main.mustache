{{!
    @template local_academic_summary/main
    Template purpose and description.

    Example context (json):
    {
        "returnurl": "http://example.com",
        "users": [
            {
                "userid": 1,
                "fullname": "John Doe",
                "lastaccess": "2026-03-13",
                "totalcourses": 5,
                "averageprogress": 80,
                "iscourses": true,
                "courses": [
                    {
                        "coursename": "Math 101",
                        "startdate": "2026-01-01",
                        "enddate": "2026-03-01",
                        "percentage": 50,
                        "hascompletion": true,
                        "iscompleted": false,
                        "isinprogress": true,
                        "isnotstarted": false,
                        "isnotactive": false,
                        "linkcourse": "http://example.com/course/view.php?id=2"
                    }
                ]
            }
        ],
        "upcomingevents": {
            "events": [
                {"eventname": "Exam", "eventdate": "2026-03-20"}
            ]
        }
    }
}}

<div class="container-fluid">
	<div class="row">
		<div class="col-12">
			<a href="{{returnurl}}" class="float-end btn btn-primary"><i class="fa-solid fa-arrow-left mr-1"></i>{{#str}}return, local_academic_summary{{/str}}</a>
		</div>
	</div>
	<div class="row">
		<div class="col-md-6">
			{{{formsummary}}}
		</div>
	</div>

<div class="row">
	<table class="table table-striped">
		<thead>
			<tr>
				<th>{{#str}}fullname, core{{/str}}</th>
				<th>{{#str}}lastaccess, core{{/str}}</th>
				<th>{{#str}}totalcourses, local_academic_summary{{/str}}</th>
				<th>{{#str}}averageprogress, local_academic_summary{{/str}}</th>
				<th>{{#str}}actions, local_academic_summary{{/str}}</th>
			</tr>
		</thead>
		<tbody>
			{{#users}}
			<tr>
				<td>{{fullname}}</td>
				<td>{{lastaccess}}</td>
				<td>{{totalcourses}}</td>
				<td>{{averageprogress}}%</td>
				<td>
					<button class="btn btn-primary" 
							data-toggle="modal" 
							data-target="#modal-{{userid}}">
						<i class="fa-solid fa-eye mr-2"></i>{{#str}}viewdetail, local_academic_summary{{/str}}
					</button>
				</td>
				{{#iscourses}}
					
				{{/iscourses}}
			</tr>

			
			{{/users}}
			{{^users}}
			<tr>
				<td colspan="5" class="text-center text-muted">{{#str}}nosearchresults, local_academic_summary{{/str}}</td>
			</tr>
			{{/users}}
		</tbody>
	</table>
</div>
</div>
{{! Modal de detalle por usuario }}
{{#users}}
<div class="modal fade" id="modal-{{userid}}" tabindex="-1">
	<div class="modal-dialog modal-xl">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">{{fullname}}</h5>
				<button type="button" class="close" data-dismiss="modal">
					<span>&times;</span>
				</button>
			</div>
		<div class="modal-body">
			{{! Lista de cursos }}
			<table class="table table-md table-striped mb-0">
				<thead>
					<tr>
						<th>{{#str}}coursename, local_academic_summary{{/str}}</th>
						<th>{{#str}}startdate, local_academic_summary{{/str}}</th>
						<th>{{#str}}enddate, local_academic_summary{{/str}}</th>
						<th>{{#str}}progress, local_academic_summary{{/str}}</th>
						<th>{{#str}}status, local_academic_summary{{/str}}</th>
						<th>{{#str}}link, local_academic_summary{{/str}}</th>
					</tr>
				</thead>
				<tbody>
				{{#courses}}
					<tr>
						<td>{{coursename}}</td>
						<td>{{startdate}}</td>
						<td>{{enddate}}</td>
						<td>
						{{#hascompletion}}
						<div class="progress">
							<div class="progress-bar" style="width: {{percentage}}%">
									{{percentage}}%
							</div>
						</div>
							{{/hascompletion}}
							{{^hascompletion}}
							<span class="text-muted">{{#str}}notracking, local_academic_summary{{/str}}</span>
							{{/hascompletion}}
						</td>
						<td>
						{{#iscompleted}}<span class="badge badge-success">{{#str}}completed, local_academic_summary{{/str}}</span>{{/iscompleted}}
						{{#isinprogress}}<span class="badge badge-warning">{{#str}}inprogress, local_academic_summary{{/str}}</span>{{/isinprogress}}
						{{#isnotstarted}}<span class="badge badge-secondary">{{#str}}withoutstarting, local_academic_summary{{/str}}</span>{{/isnotstarted}}
						{{#isnotactive}}<span class="badge badge-danger">{{#str}}notracking, local_academic_summary{{/str}}</span>{{/isnotactive}}
						</td>
						<td><a href="{{linkcourse}}" target="_blank" class="text-decoration-none"><i class="fa-solid fa-arrow-up-right-from-square ml-2"></i></a></td>
						</tr>
						{{/courses}}
						{{^courses}}
						<tr>
							<td colspan="5" class="text-center text-muted">{{#str}}nosearchresults, local_academic_summary{{/str}}</td>
							</tr>
						{{/courses}}
				</tbody>
			</table>
			<hr class="mt-0">
			{{! Próximas entregas }}
			<h6>{{#str}}upcomingevents, local_academic_summary{{/str}}</h6>
				{{#upcomingevents}}
					<ul class="list-group">
						{{#events}}
						<li class="list-group-item">{{eventname}} — {{eventdate}}</li>
						{{/events}}
					</ul>
					{{/upcomingevents}}
					{{^upcomingevents}}
				<p class="text-muted">{{#str}}noupcomingevents, local_academic_summary{{/str}}</p>
					{{/upcomingevents}}
			</div>
		</div>
	</div>
</div>
{{/users}}